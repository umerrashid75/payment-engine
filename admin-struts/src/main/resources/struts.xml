<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <constant name="struts.devMode" value="false" />
    <constant name="struts.objectFactory" value="spring" />
    <!-- Keep Spring Boot endpoints (actuator) out of the Struts dispatcher. -->
    <constant name="struts.action.excludePattern" value="/actuator/.*" />

    <package name="default" extends="struts-default" namespace="/">
        <action name="cards" class="com.coreissuer.admin.action.CardAction" method="list">
            <result name="success">/WEB-INF/views/cards.jsp</result>
        </action>

        <action name="updateCardStatus" class="com.coreissuer.admin.action.CardAction" method="updateStatus">
            <!-- Session token blocks CSRF and duplicate form submissions. -->
            <interceptor-ref name="token"/>
            <interceptor-ref name="defaultStack"/>
            <result name="success" type="redirectAction">
                <param name="actionName">cards</param>
            </result>
            <result name="invalid.token" type="redirectAction">
                <param name="actionName">cards</param>
            </result>
        </action>
    </package>
</struts>
