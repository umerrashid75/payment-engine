# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to git.

# Required — no default. Application fails to start if unset.
COREISSUER_PEPPER=change-me-to-a-long-random-secret

# Optional — defaults shown below match the docker-compose MySQL service.
# DB_URL=jdbc:mysql://localhost:3306/coreissuer?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_USER=coreissuer
# DB_PASSWORD=coreissuer
# SERVER_PORT=8080
