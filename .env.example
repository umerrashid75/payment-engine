# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to git.

# Required — no default. Application fails to start if unset.
COREISSUER_PEPPER=change-me-to-a-long-random-secret

# Required — HTTP Basic credentials for /api/v1/admin/** endpoints.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional — merchant endpoint that receives transaction webhooks.
# Leave empty to disable webhook deliveries.
# WEBHOOK_TARGET_URL=https://example.com/webhooks/coreissuer

# Optional — defaults shown below match the docker-compose MySQL service.
# DB_URL=jdbc:mysql://localhost:3306/coreissuer?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_USER=coreissuer
# DB_PASSWORD=coreissuer
# MYSQL_ROOT_PASSWORD=root
# SERVER_PORT=8080
# RECON_REPORT_DIR=reports
